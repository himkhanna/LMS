NEXT_PUBLIC_API_BASE_URL=http://localhost:8081
NEXT_PUBLIC_AI_GATEWAY_URL=http://localhost:8082
NEXT_PUBLIC_AUTH_BASE_URL=http://localhost:8083

# Microsoft (Entra ID) OIDC — frontend builds the authorize URL with these.
# Set MS_TENANT_ID, MS_CLIENT_ID, MS_CLIENT_SECRET on the auth-service to match.
NEXT_PUBLIC_MS_TENANT_ID=common
NEXT_PUBLIC_MS_CLIENT_ID=
NEXT_PUBLIC_MS_REDIRECT_URI=http://localhost:3000/auth/callback
